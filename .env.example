# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Auth + persistencia SGI (usuarios administrados)
# 1. Crear proyecto en https://supabase.com
# 2. Ejecutar supabase/schema.sql en SQL Editor
# 3. Crear usuario en Authentication y fila en sgi_app_users (ver .cursor/skills/supabase-sgi-auth/)
# 4. Desactivar confirmación de email si es app interna (Authentication → Providers → Email)
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
